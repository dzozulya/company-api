APP_NAME=CompanyVersionsAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=company_versions
DB_USERNAME=laravel
DB_PASSWORD=secret

# Cache / Queue

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120



# Mail (not used in task but left for extension)

MAIL_MAILER=log
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="[noreply@example.com](mailto:noreply@example.com)"
MAIL_FROM_NAME="${APP_NAME}"

# API

API_RATE_LIMIT=60
